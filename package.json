{
  "name": "cursor-sdk-server",
  "version": "0.1.0",
  "description": "Unofficial OpenAI Responses API HTTP server backed by @cursor/sdk agents",
  "private": true,
  "license": "MIT",
  "author": "Pratham Dubey",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prathamdby/cursor-sdk-server.git"
  },
  "homepage": "https://github.com/prathamdby/cursor-sdk-server",
  "bugs": {
    "url": "https://github.com/prathamdby/cursor-sdk-server/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check:code": "bun run typecheck && bun run lint && bun run fmt:check"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.13",
    "@elysiajs/cors": "^1.3.0",
    "elysia": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^5.8.0"
  }
}
